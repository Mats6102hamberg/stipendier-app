generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Stipendium {
  id           String    @id @default(cuid())
  namn         String
  organisation String
  beskrivning  String
  belopp       Int?
  beloppMax    Int?
  deadline     DateTime?
  kategorier   String[]
  målgrupp     String[]
  url          String?
  aktiv        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deadline])
}
