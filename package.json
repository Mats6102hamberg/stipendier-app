{
  "name": "stipendier-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:seed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "scrap": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/scrapStipendier.ts",
    "embed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/embedStipendier.ts",
    "vectors:setup": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/setupVectors.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@stripe/stripe-js": "^9.0.1",
    "cheerio": "^1.2.0",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^21.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
